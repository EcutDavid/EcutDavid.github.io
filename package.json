{
  "name": "davidg-protfolio",
  "private": true,
  "version": "0.0.1",
  "main": "",
  "scripts": {
    "clean": "rimraf assets && rimraf dist",
    "copy": "copyfiles -f ./src/favicon.ico ./dist",
    "publish": "npm run clean && npm run dist && cp -R ./dist/assets/ ./assets && cp ./dist/favicon.ico ./favicon.ico && cp ./dist/index.html ./index.html",
    "dist": "rimraf assets && npm run copy & webpack --mode production --config webpack.dist.js",
    "serve": "webpack serve --mode development --config webpack.dev.js",
    "serve:dist": "webpack serve --mode production --config webpack.dist.js",
    "start": "webpack --mode development --watch --config webpack.dev.js",
    "lint": "eslint ./src"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/plugin-transform-object-rest-spread": "^7.24.0",
    "babel-loader": "^9.1.3",
    "copyfiles": "^2.4.1",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.0",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "normalize.css": "^8.0.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "three": "^0.170.0"
  }
}
